  "specific_module_instructions": {
    "pos": {
      "layout": "3-Column Density",
      "interactions": "Optimistic UI for add-to-cart. Sound effects on success. Keyboard shortcuts (F1-F12) for categories.",
      "visuals": "High contrast text. No gradients on item cards."
    },
    "kitchen": {
      "layout": "Kanban / Masonry",
      "font": "Large readable text (text-xl) for order numbers",
      "alerts": "Flash card red if time > 20mins"
    }
  },
  "universal_guidelines": [
    "Do NOT use gradients for backgrounds (Solid Obsidian #0A0A0A).",
    "Do NOT use rounded-full buttons for primary actions (Use rounded-md).",
    "Use 'sonner' for all toast notifications.",
    "Ensure 'data-testid' is present on all interactive elements.",
    "Dark mode is the default for POS; Light mode is secondary."
  ]
